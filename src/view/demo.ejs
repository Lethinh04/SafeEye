    <!-- ═══════════════ SCREENSHOT PREVIEW MODAL ═══════════════ -->
    <div id="snapshot-modal"
        class="hidden fixed inset-0 z-[999] flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
        <div class="bg-surface-dark rounded-2xl border border-slate-700 shadow-2xl max-w-lg w-full overflow-hidden">
            <div class="px-4 py-3 border-b border-slate-800 flex items-center justify-between">
                <span class="font-bold text-sm flex items-center gap-2">
