<!DOCTYPE html>
<html class="dark" lang="vi">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>SafeEye — Demo Nhận Diện AI Thời Gian Thực</title>
    <meta name="description"
        content="SafeEye sử dụng YOLOv8 để nhận diện vật thể thời gian thực qua webcam, phân tích an toàn khu vực làm việc." />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#3b82f6",
                        "primary-dark": "#2563eb",
                        "success": "#10b981",
                        "warning": "#f59e0b",
                        "danger": "#ef4444",
                        "bg-light": "#f0f4ff",
                        "bg-dark": "#0b0f1a",
                        "surface-dark": "#111827",
                        "surface-dark2": "#1f2937",
                    },
                    fontFamily: { "display": ["Space Grotesk"] },
                    animation: {
                        "pulse-slow": "pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite",
                        "scan": "scan 2s linear infinite",
                        "fadeInUp": "fadeInUp 0.3s ease-out",
                        "glow": "glow 2s ease-in-out infinite alternate",
                    },
                    keyframes: {
                        scan: { "0%": { top: "0%" }, "100%": { top: "100%" } },
                        fadeInUp: { "0%": { opacity: 0, transform: "translateY(8px)" }, "100%": { opacity: 1, transform: "translateY(0)" } },
                        glow: { "0%": { boxShadow: "0 0 5px rgba(59,130,246,0.4)" }, "100%": { boxShadow: "0 0 20px rgba(59,130,246,0.8), 0 0 40px rgba(59,130,246,0.4)" } },
                    }
                },
            },
        }
    </script>
    <style>
        body {
            font-family: "Space Grotesk", sans-serif;
        }

        /* ─── Bounding Box ─── */
        .bbox {
            position: absolute;
            border: 2px solid;
            border-radius: 3px;
            pointer-events: none;
            animation: fadeInUp 0.2s ease-out;
            transition: all 0.1s ease;
        }

        .bbox-label {
            position: absolute;
            top: -22px;
            left: -2px;
            padding: 1px 7px;
            font-size: 10px;
            font-weight: 700;
            color: white;
            border-radius: 3px 3px 0 0;
            white-space: nowrap;
            font-family: "Space Grotesk", sans-serif;
        }

        /* ─── Scan line ─── */
        .scan-line {
            position: absolute;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, #3b82f6 50%, transparent);
            opacity: 0.7;
            animation: scan 2.5s linear infinite;
            pointer-events: none;
        }

        /* ─── Corner decorations ─── */
        .corner {
            position: absolute;
            width: 18px;
            height: 18px;
        }

        .corner-tl {
            top: 8px;
            left: 8px;
            border-top: 2px solid #3b82f6;
            border-left: 2px solid #3b82f6;
        }

        .corner-tr {
            top: 8px;
            right: 8px;
            border-top: 2px solid #3b82f6;
            border-right: 2px solid #3b82f6;
        }

        .corner-bl {
            bottom: 8px;
            left: 8px;
            border-bottom: 2px solid #3b82f6;
            border-left: 2px solid #3b82f6;
        }

        .corner-br {
            bottom: 8px;
            right: 8px;
            border-bottom: 2px solid #3b82f6;
            border-right: 2px solid #3b82f6;
        }

        /* ─── Activity log item ─── */
        .log-item {
            animation: fadeInUp 0.3s ease-out;
        }

        /* ─── Confidence bar ─── */
        .conf-bar {
            transition: width 0.4s ease;
        }

        /* ─── Card hover ─── */
        .stat-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(59, 130, 246, 0.15);
        }

        /* ─── Sidebar scrollbar ─── */
        .thin-scroll::-webkit-scrollbar {
            width: 4px;
        }

        .thin-scroll::-webkit-scrollbar-track {
            background: transparent;
        }

        .thin-scroll::-webkit-scrollbar-thumb {
            background: #374151;
            border-radius: 4px;
        }

        /* ─── Button ripple ─── */
        .btn-primary {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            transition: all 0.2s ease;
            position: relative;
            overflow: hidden;
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(59, 130, 246, 0.45);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        /* ─── Status pulse ─── */
        @keyframes statusPulse {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.4;
            }
        }

        .status-dot-active {
            animation: statusPulse 1.5s ease-in-out infinite;
        }

        /* ─── Video overlay ─── */
        #video-wrapper {
            position: relative;
            background: #000;
        }

        #overlay-canvas {
            position: absolute;
            top: 0;
            left: 0;
            pointer-events: none;
        }

        /* ─── Model indicator ─── */
        .model-badge {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(37, 99, 235, 0.1));
            border: 1px solid rgba(59, 130, 246, 0.3);
        }

        /* ─── Toggle ─── */
        .toggle-track {
            transition: background 0.3s ease;
        }

        .toggle-thumb {
            transition: transform 0.3s ease;
        }
    </style>
</head>

<body class="bg-bg-dark text-slate-100 min-h-screen antialiased">
    <div class="relative flex h-full min-h-screen w-full flex-col overflow-x-hidden">

        <!-- ═══════════════ HEADER ═══════════════ -->
        <header
            class="flex items-center justify-between border-b border-slate-800 px-5 py-3 bg-surface-dark sticky top-0 z-50 shadow-lg shadow-black/30">
            <div class="flex items-center gap-3">
