    <!-- ═══════════════ JAVASCRIPT ═══════════════ -->
    <script>
        // Throttle settings for pushes (client -> server)
        let lastFirebasePush = 0;
        const FIREBASE_PUSH_INTERVAL = 2000; // ms

        // Summarize detections into the 4 groups requested
        function summarizeDetections(detections) {
            const summary = { "Không có gì": 0, "Người": 0, "Bàn": 0, "1.000 VND": 0 };
            if (!detections || detections.length === 0) {
                summary["Không có gì"] = 1;
                return summary;
            }
            detections.forEach(d => {
                const raw = (d.label_tts || d.label || '').toString().toLowerCase();
                if (/người|person|people|human/.test(raw)) { summary["Người"] += 1; return; }
                if (/bàn|table|dining table|bàn ăn/.test(raw)) { summary["Bàn"] += 1; return; }
                if (/1000|1\.000|1k|vnd|\bđ\b|dong|tiền|banknote|money/.test(raw)) { summary["1.000 VND"] += 1; return; }
            });
            return summary;
        }
        /* ─── Config ─── */
        const API_BASE = "http://localhost:5050";

        /* ─── State ─── */
        let stream = null;
        let detectInterval = null;
        let isDetecting = false;
        let showLabels = true;
        let enableVoice = false;
        let totalDetected = 0;
        let logEntries = [];
        let exportData = [];
        let lastDetections = {};   // class_label -> count
        let apiOk = false;
        let isProcessing = false;

        /* ─── DOM refs ─── */
        const video = document.getElementById("webcam");
        const overlay = document.getElementById("overlay-canvas");
        const capCanvas = document.getElementById("capture-canvas");
        const ctx = overlay.getContext("2d");

        /* ─── On load: ping API ─── */
        window.addEventListener("DOMContentLoaded", () => {
            pingAPI();
            setInterval(pingAPI, 5000);
        });

        async function pingAPI() {
            try {
                const r = await fetch(API_BASE + "/health", { signal: AbortSignal.timeout(3000) });
                if (r.ok) {
                    apiOk = true;
                    document.getElementById("api-status").textContent = "API: OK";
                    document.getElementById("api-status").className = "font-medium text-green-400";
                    return;
                }
            } catch (_) { }
            apiOk = false;
            document.getElementById("api-status").textContent = "API: Offline";
            document.getElementById("api-status").className = "font-medium text-red-400";
        }

        /* ─── Camera ─── */
        async function startCamera() {
            try {
                video.src = "/proxy-stream";
                video.onload = () => {
                    overlay.width = video.naturalWidth || 1280;
                    overlay.height = video.naturalHeight || 720;
                    // Tối ưu: Thu nhỏ kích thước ảnh gửi lên server để tăng tối đa FPS
                    capCanvas.width = 640;
                    capCanvas.height = 360;
                    stream = true;
                };
                // Show UI
                document.getElementById("camera-placeholder").classList.add("hidden");
                document.getElementById("live-badge").classList.remove("hidden");
                document.getElementById("cam-label").classList.remove("hidden");
                document.getElementById("cam-label").textContent = "Pi Camera (MJPEG)";
                document.getElementById("model-badge").classList.remove("hidden");
                document.getElementById("camera-icon").textContent = "videocam";
                document.getElementById("detect-btn").disabled = false;
                setStatus("active", "Camera bật");
                addLog("🟢", "Đã kết nối Pi Camera", "primary");
            } catch (e) {
                addLog("🔴", "Không thể kết nối Pi Camera: " + e.message, "danger");
            }
        }

        function stopCamera() {
            stream = null;
            video.src = "";
            stopDetection();
            ctx.clearRect(0, 0, overlay.width, overlay.height);
            document.getElementById("camera-placeholder").classList.remove("hidden");
            document.getElementById("live-badge").classList.add("hidden");
            document.getElementById("cam-label").classList.add("hidden");
            document.getElementById("model-badge").classList.add("hidden");
            document.getElementById("detect-btn").disabled = true;
            setStatus("idle", "Camera tắt");
            addLog("⚫", "Camera đã tắt", "slate");
        }

        function toggleCamera() {
            if (stream) stopCamera(); else startCamera();
        }

        /* ─── Detection ─── */
        function startDetection() {
            if (!stream) return;
            if (!apiOk) {
                addLog("⚠️", "API chưa kết nối. Vui lòng chạy demo_api.py", "warning");
                return;
            }
            const intervalMs = parseInt(document.getElementById("interval-select").value);
            isDetecting = true;
            detectInterval = setInterval(runDetect, intervalMs);
            document.getElementById("detect-icon").textContent = "pause";
            document.getElementById("scan-line").classList.remove("hidden");
            setStatus("active", "Đang nhận diện");
            addLog("🔵", "Bắt đầu nhận diện AI", "primary");
        }

        function stopDetection() {
            isDetecting = false;
            clearInterval(detectInterval);
            detectInterval = null;
            ctx.clearRect(0, 0, overlay.width, overlay.height);
            document.getElementById("detect-icon").textContent = "play_arrow";
            document.getElementById("scan-line").classList.add("hidden");
            if (stream) setStatus("active", "Camera bật");
        }

        function toggleDetection() {
            if (isDetecting) stopDetection(); else startDetection();
        }

        let lastAudioTime = 0;

        function playAudio(base64Audio) {
            if (!enableVoice || !base64Audio) return;
            const now = Date.now();
            if (now - lastAudioTime < SPEAK_INTERVAL) return;

            lastAudioTime = now;
            new Audio("data:audio/wav;base64," + base64Audio).play();
        }

        async function runDetect() {
            if (!stream || !video.complete || video.naturalWidth === 0 || isProcessing) return;

            isProcessing = true;

            const ctxCap = capCanvas.getContext("2d");
            ctxCap.save();
            ctxCap.translate(capCanvas.width, 0);
            ctxCap.scale(-1, 1);
            ctxCap.drawImage(video, 0, 0, capCanvas.width, capCanvas.height);
            ctxCap.restore();
            const imageData = capCanvas.toDataURL("image/jpeg", 0.7);

            const conf = parseInt(document.getElementById("conf-slider").value) / 100;
            const t0 = performance.now();

            try {
                const resp = await fetch(API_BASE + "/detect", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ image: imageData, conf }),
                    signal: AbortSignal.timeout(5000),
                });

                if (!resp.ok) throw new Error("HTTP " + resp.status);

                const data = await resp.json();
                if (enableVoice && data.speech) {
                    handleSpeech(data.speech);
                }
                const latency = Math.round(performance.now() - t0);

                if (data.processed_image) {
                    const imgEl = document.getElementById("processed-video");
                    imgEl.src = data.processed_image;
                    imgEl.classList.remove("hidden");
                }

                updateStats(data, latency);

            } catch (e) {
                console.warn("[SafeEye] detect error:", e.message);
            }

            isProcessing = false;
        }

        /* ─── Render bounding boxes on canvas ─── */
        function renderDetections(detections) {
            // Function disabled since server now returns processed image
            const cw = overlay.width;
            const ch = overlay.height;
            ctx.clearRect(0, 0, cw, ch);
        }

        /* ─── Update statistics ─── */
        function updateStats(data, latency) {
            const newTotal = data.total;
            totalDetected += newTotal;

            document.getElementById("stat-total").textContent = String(newTotal).padStart(2, "0");
            document.getElementById("stat-fps").textContent = data.fps || "--";
            document.getElementById("stat-latency").textContent = latency;

            // Check for new detections to log
            const newCounts = data.class_counts || {};
            for (const [label, count] of Object.entries(newCounts)) {
                if (!lastDetections[label] || lastDetections[label] !== count) {
                    addLog("🔍", `Phát hiện ${count}x ${label}`, "primary");
                }
            }
            lastDetections = { ...newCounts };

            // Update detection list sidebar
            renderDetectionList(data.detections);

            // Push summary + detections to Firebase (throttled)
            try {
                const summary = summarizeDetections(data.detections);
                if (Date.now() - lastFirebasePush > FIREBASE_PUSH_INTERVAL) {
                    lastFirebasePush = Date.now();
                    const payload = { summary: summary };
                    fetch('/api/detections', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    }).then(r => r.json()).then(j => {
                        if (j.ok) console.log('Server stored detection id', j.id); else console.warn('Server response', j);
                    }).catch(err => console.warn('Push to server error', err));
                }
            } catch (err) {
                console.warn('Push to Firebase error', err);
            }

            // Export data
            exportData.push({
                timestamp: new Date().toISOString(),
                total: newTotal,
                latency_ms: latency,
                fps: data.fps,
                classes: JSON.stringify(newCounts),
            });
        }

        /* ─── Detection sidebar list ─── */
        function renderDetectionList(detections) {
            const list = document.getElementById("detection-list");
            const empty = document.getElementById("empty-detection");
            const badge = document.getElementById("detect-count-badge");

            badge.textContent = detections.length;

            if (detections.length === 0) {
                empty.classList.remove("hidden");
                // Remove old items
                list.querySelectorAll(".det-item").forEach(el => el.remove());
                return;
            }
            empty.classList.add("hidden");

            // Group by label
            const groups = {};
            for (const d of detections) {
                if (!groups[d.label]) groups[d.label] = { ...d, count: 0 };
                groups[d.label].count++;
                if (d.confidence > groups[d.label].confidence) groups[d.label].confidence = d.confidence;
            }

            // Clear and re-render
            list.querySelectorAll(".det-item").forEach(el => el.remove());
            for (const [label, info] of Object.entries(groups)) {
                const div = document.createElement("div");
                div.className = "det-item flex items-center justify-between p-2.5 rounded-xl border animate-fadeInUp";
                div.style.cssText = `background:${info.color}15; border-color:${info.color}40;`;
                div.innerHTML = `
                    <div class="flex items-center gap-2">
                        <div class="size-7 rounded-lg flex items-center justify-center" style="background:${info.color}30">
                            <span class="text-[9px] font-black" style="color:${info.color}">${label.slice(0, 2).toUpperCase()}</span>
                        </div>
                        <div>
                            <p class="text-xs font-bold">${label}</p>
                            <div class="flex items-center gap-1 mt-0.5">
                                <div class="w-16 h-1 rounded-full bg-slate-700 overflow-hidden">
                                    <div class="h-full rounded-full conf-bar" style="width:${Math.round(info.confidence * 100)}%;background:${info.color}"></div>
                                </div>
                                <span class="text-[9px] text-slate-400">${Math.round(info.confidence * 100)}%</span>
                            </div>
                        </div>
                    </div>
                    <span class="text-lg font-black" style="color:${info.color}">${String(info.count).padStart(2, "0")}</span>
                `;
                list.appendChild(div);
            }
        }

        /* ─── Activity log ─── */
        function addLog(icon, message, colorKey = "primary") {
            const colorMap = {
                primary: "#3b82f6", success: "#10b981", warning: "#f59e0b",
                danger: "#ef4444", slate: "#94a3b8"
            };
            const color = colorMap[colorKey] || colorMap.primary;
            const timeStr = new Date().toLocaleTimeString("vi-VN", { hour: "2-digit", minute: "2-digit", second: "2-digit" });

            const emptyLog = document.getElementById("empty-log");
            emptyLog?.classList.add("hidden");

            const log = document.getElementById("activity-log");
            const item = document.createElement("div");
            item.className = "log-item flex gap-2.5 text-xs";
            item.innerHTML = `
                <div class="w-0.5 rounded-full mt-1 flex-shrink-0" style="background:${color}; min-height: 16px;"></div>
                <div class="flex-1 min-w-0">
                    <p class="font-medium text-slate-200 truncate">${icon} ${message}</p>
                    <p class="text-slate-500 text-[10px]">${timeStr}</p>
                </div>
            `;
            log.insertBefore(item, log.firstChild);

            // Keep max 30 entries
            const items = log.querySelectorAll(".log-item");
            if (items.length > 30) items[items.length - 1].remove();
        }

        function clearLog() {
            const log = document.getElementById("activity-log");
            log.querySelectorAll(".log-item").forEach(el => el.remove());
            document.getElementById("empty-log").classList.remove("hidden");
        }

        function clearResults() {
            ctx.clearRect(0, 0, overlay.width, overlay.height);
            renderDetectionList([]);
            document.getElementById("stat-total").textContent = "00";
            document.getElementById("stat-fps").textContent = "--";
            document.getElementById("stat-latency").textContent = "--";
            lastDetections = {};
        }

        /* ─── Snapshot ─── */
        function captureSnapshot() {
            if (!stream) { alert("Vui lòng bật camera trước."); return; }

            // Merge video + overlay canvas
            const snap = document.createElement("canvas");
            snap.width = video.naturalWidth || 1280;
            snap.height = video.naturalHeight || 720;
            const sctx = snap.getContext("2d");
            sctx.save();
            sctx.translate(snap.width, 0);
            sctx.scale(-1, 1);
            sctx.drawImage(video, 0, 0);
            sctx.restore();
            sctx.drawImage(overlay, 0, 0);

            const dataUrl = snap.toDataURL("image/png");
            document.getElementById("snapshot-img").src = dataUrl;
            document.getElementById("snapshot-download").href = dataUrl;
            document.getElementById("snapshot-modal").classList.remove("hidden");
            addLog("📸", "Đã chụp ảnh màn hình", "success");
        }

        function closeSnapshot() {
            document.getElementById("snapshot-modal").classList.add("hidden");
        }

        /* ─── Export CSV ─── */
        function exportCSV() {
            if (exportData.length === 0) {
                alert("Chưa có dữ liệu để xuất. Hãy chạy nhận diện trước.");
                return;
            }
            const headers = ["timestamp", "total_objects", "latency_ms", "fps", "classes"];
            const rows = exportData.map(r =>
                [r.timestamp, r.total, r.latency_ms, r.fps, r.classes].join(",")
            );
            const csv = [headers.join(","), ...rows].join("\n");
            const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
            const url = URL.createObjectURL(blob);
            const a = document.createElement("a");
            a.href = url; a.download = "safeeye-report.csv";
            a.click();
            URL.revokeObjectURL(url);
            addLog("📊", `Đã xuất ${exportData.length} bản ghi CSV`, "success");
        }

        /* ─── Status ─── */
        function setStatus(state, label) {
            const dot = document.getElementById("status-dot");
            const text = document.getElementById("status-text");
            text.textContent = label;
            if (state === "active") {
                dot.className = "inline-flex h-2 w-2 rounded-full bg-green-500 status-dot-active";
                text.className = "font-medium text-green-400";
            } else {
                dot.className = "inline-flex h-2 w-2 rounded-full bg-red-500";
                text.className = "font-medium text-slate-400";
            }
        }

        /* ─── Settings ─── */
        function toggleSettings() {
            document.getElementById("settings-panel").classList.toggle("hidden");
        }

        function updateConfLabel(val) {
            document.getElementById("conf-label").textContent = val + "%";
        }

        /* ─── Keyboard shortcuts ─── */
        document.addEventListener("keydown", (e) => {
            if (e.key === " " && !e.target.matches("input,select")) {
                e.preventDefault();
                toggleDetection();
            }
            if (e.key === "Escape") closeSnapshot();
        });
    </script>
</body>

</html>